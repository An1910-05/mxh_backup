# =============================================================================
# MXH — biến môi trường cho Docker Compose (đặt file này thành `.env` ở thư mục gốc repo)
# =============================================================================

# Hostname hoặc IP công khai (không có http://) — trình duyệt user dùng để mở frontend.
# Ví dụ: localhost | tenmien.com | 203.0.113.10
MXH_PUBLIC_HOST=localhost

# Profile Docker Compose: `local-db` = chạy thêm container MySQL trên cùng máy.
# Triển khai VPS mà MySQL ở máy nhà: XÓA dòng này hoặc để trống (không dùng container MySQL).
COMPOSE_PROFILES=local-db

# --- Kết nối MySQL (backend + websocket + migrate/seed) ---
# Khi COMPOSE_PROFILES=local-db: DB_HOST=mysql (tên service Docker).
# Khi DB tại máy nhà: DB_HOST = IP/domain máy nhà, Tailscale IP, hoặc 127.0.0.1 nếu dùng SSH tunnel trên VPS.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=mxh_social
DB_USER=root
DB_PASS=root

# MySQL trong Docker (chỉ khi dùng profile local-db)
MYSQL_ROOT_PASSWORD=root
# Cổng publish MySQL ra máy host (tránh trùng cổng nếu máy đã có MySQL)
MYSQL_PUBLISH_PORT=3307

# --- Bảo mật ---
# Đổi JWT_SECRET trên môi trường production.
APP_ENV=local
JWT_SECRET=mxh-dev-secret-key-2024
JWT_EXPIRY=86400

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=iPock

# --- URL ứng dụng (CORS) & Vite ---
# Nếu KHÔNG đặt APP_URL / FRONTEND_URL / VITE_*: Compose dùng http:// + MXH_PUBLIC_HOST + cổng mặc định.
# Production HTTPS: bỏ comment và chỉnh domain thật (khớp origin trình duyệt).
# APP_URL=https://api.example.com
# FRONTEND_URL=https://example.com
# VITE_API_URL=https://api.example.com
# VITE_GRAPHQL_URL=https://api.example.com/graphql
# VITE_WS_URL=wss://ws.example.com
# (WebSocket thường dùng subdomain riêng qua Nginx — xem deploy/nginx-mxh.example.conf)

# --- Tùy chọn: MySQL qua TLS (khi bắt buộc SSL) ---
# Đường dẫn file CA *trong container* backend (mount volume nếu cần)
# DB_SSL_CA=
# DB_SSL_VERIFY=1
# DB_SSL_VERIFY=0

# Thời gian chờ TCP tới MySQL khi container khởi động (giây)
DB_WAIT_TIMEOUT=120

# --- VNPay ---
# Sandbox credentials sẵn (override bằng cách đặt biến tại đây)
# VNP_TMN_CODE=5UQ9JN3J
# VNP_HASH_SECRET=4ADPX1KAMS0N2GKFA834HHVT0A6DELTO
# VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# --- MoMo (One-Time Payment v2 - captureWallet) ---
# Credentials sandbox công khai của MoMo (dùng được ngay với MoMo TEST app).
# Production: thay bằng credentials thật cấp khi onboarding merchant.
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=F8BBA842ECF85
MOMO_SECRET_KEY=K951B6PE1waDMi640xX08PD3vg6EkVlz
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# URL backend (cho ipnUrl — MoMo gọi server-to-server). Để trống → mặc định http://localhost:8000.
# Khi test local: không đặt được public URL → IPN không tới được; PaymentResultPage sẽ finalize khi user redirect về.
# BACKEND_URL=https://api.example.com

# Mock VNPay/MoMo cho dev local khi sandbox CHƯA duyệt URL whitelist.
# Bật (=1) → bỏ qua cổng thanh toán, redirect thẳng về /payment/result với success giả lập + cộng tiền vào balance.
# Tắt (=0 hoặc bỏ trống) → dùng sandbox/production thật.
# CẢNH BÁO: KHÔNG bật ở production.
PAYMENT_MOCK=0

# Cổng publish dịch vụ (nếu cần đổi)
# BACKEND_PUBLISH_PORT=8000
# WEBSOCKET_PUBLISH_PORT=8080
# FRONTEND_PUBLISH_PORT=5173
